WORK_DIR="$(dirname "$(readlink -f "${0}")")"
source /usr/share/libubox/jshn.sh
source "${WORK_DIR}/natmap_callback.config"

CLOUDFLARE_DNS_API_URL="${CLOUDFLARE_API_URL}/dns_records"

# ==============================================================
# API success 检查
# 流程: json_cleanup → json_init → json_load → json_get_var → 判断
# "success":true → let 设=1 → json_get_var 读到 "1" → [ "$ok" = "1" ] 成立 → return 0
# "success":false → let 设=0 → json_get_var 读到 "0" → [ "$ok" = "1" ] 不成立 → return 1
# ==============================================================
_api_ok() {
    local resp="$1"
    json_cleanup
    json_init
    json_load "${resp}"
    local ok
    json_get_var ok success
    [ "$ok" = "1" ] && return 0
    return 1
}

# ==============================================================
# DNS 记录查询
# ==============================================================

record_query() {
    local sub_domain="$1"
    curl -s -X GET "${CLOUDFLARE_DNS_API_URL}?type=A&name=${sub_domain}" \
        -H "Authorization: Bearer ${AUTH}" \
        -H "Content-Type: application/json"
}

# ==============================================================
# 用 jshn.sh 提取 result[0].field
# 流程: json_load → json_select result → json_select 0 → json_get_var
# ==============================================================

record_id_from_json() {
    local resp="$1"
    json_cleanup
    json_init
    json_load "${resp}"
    json_select result
    [ $? -ne 0 ] && { json_cleanup; echo ""; return 1; }
    json_select "0"
    [ $? -ne 0 ] && { json_cleanup; echo ""; return 1; }
    local id
    json_get_var id id
    json_cleanup
    echo "${id}"
}

record_ip_from_json() {
    local resp="$1"
    json_cleanup
    json_init
    json_load "${resp}"
    json_select result
    [ $? -ne 0 ] && { json_cleanup; echo ""; return 1; }
    json_select "0"
    [ $? -ne 0 ] && { json_cleanup; echo ""; return 1; }
    local ip
    json_get_var ip content
    json_cleanup
    echo "${ip}"
}

# ==============================================================
# DNS 记录操作（带重试）
# ==============================================================

record_add() {
    local sub_domain="$1"
    local ipaddr="$2"
    local resp i

    for ((i = 0; i < ${RETRY_NUM:-3}; i++)); do
        resp="$(curl -s -X POST "${CLOUDFLARE_DNS_API_URL}" \
            -H "Authorization: Bearer ${AUTH}" \
            -H "Content-Type: application/json" \
            --data "{\"type\":\"A\",\"name\":\"${sub_domain}\",\"content\":\"${ipaddr}\",\"proxied\":true}")"

        if _api_ok "${resp}"; then
            echo "DNS: 已添加 A 记录 ${sub_domain} -> ${ipaddr}"
            return 0
        fi
        echo "DNS: 添加记录失败（重试 ${i}）: ${resp}"
    done
    return 127
}

record_modify() {
    local sub_domain="$1"
    local ipaddr="$2"
    local record_id="$3"
    local resp i

    for ((i = 0; i < ${RETRY_NUM:-3}; i++)); do
        resp="$(curl -s -X PUT "${CLOUDFLARE_DNS_API_URL}/${record_id}" \
            -H "Authorization: Bearer ${AUTH}" \
            -H "Content-Type: application/json" \
            --data "{\"type\":\"A\",\"name\":\"${sub_domain}\",\"content\":\"${ipaddr}\",\"proxied\":true}")"

        if _api_ok "${resp}"; then
            echo "DNS: 已修改 A 记录 ${sub_domain} -> ${ipaddr}"
            return 0
        fi
        echo "DNS: 修改记录失败（重试 ${i}）: ${resp}"
    done
    return 127
}

record_upsert() {
    local sub_domain="$1"
    local ipaddr="$2"
    local resp record_id current_ip

    resp="$(record_query "${sub_domain}")"
    record_id="$(record_id_from_json "${resp}")"

    if [ -z "${record_id}" ]; then
        record_add "${sub_domain}" "${ipaddr}"
        return $?
    fi

    current_ip="$(record_ip_from_json "${resp}")"
    if [ "${current_ip}" = "${ipaddr}" ]; then
        echo "DNS: ${sub_domain} 当前 IP=${ipaddr}，无需修改"
        return 0
    fi

    record_modify "${sub_domain}" "${ipaddr}" "${record_id}"
    return $?
}

# ==============================================================
# 供 natmap_callback_main 调用的入口
# ==============================================================
access_domain_dns_records_add() {
    local public_ip="$1"
    local public_port="$2"
    local ipv6="$3"
    local private_port="$4"
    local protocol="$5"
    local private_ip="$6"

    local sub_domain
    sub_domain="$(uci -q get "natmap_callback.${private_port}")"

    if [ -z "${sub_domain}" ]; then
        echo "DNS: 未配置子域名 for port ${private_port}"
        return 0
    fi

    local full_domain="${sub_domain}.${ROOT_DOMAIN}"
    echo "DNS: 检查并更新 ${full_domain} -> ${public_ip}"
    record_upsert "${full_domain}" "${public_ip}"
    return $?
}
